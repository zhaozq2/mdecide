.container {
  padding: 16px;
  min-height: 100vh;
  background: #f5f5f5;
}

.round-indicator {
  margin-bottom: 12px;
}

.round-tabs {
  display: flex;
  gap: 8px;
  overflow-x: auto;
  padding-bottom: 8px;
}

.round-tab {
  padding: 8px 16px;
  background: #fff;
  border-radius: 16px;
  font-size: 14px;
  white-space: nowrap;
  display: flex;
  align-items: center;
  gap: 4px;
}

.round-tab.active {
  background: #1989fa;
  color: #fff;
}

.round-tab.add-round {
  border: 1px dashed #1989fa;
  color: #1989fa;
}

.round-check {
  color: #07c160;
}

.steps {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
  background: #fff;
  padding: 16px;
  border-radius: 8px;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-circle {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: #ccc;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
}

.step.active .step-circle {
  background: #1989fa;
}

.step-label {
  font-size: 12px;
  color: #666;
  margin-top: 4px;
}

.step.active .step-label {
  color: #1989fa;
}

.step-line {
  flex: 1;
  height: 2px;
  background: #ddd;
  margin: 0 4px;
}

.content {
  background: #fff;
  padding: 16px;
  border-radius: 8px;
  min-height: 400px;
}

.title {
  font-size: 18px;
  font-weight: bold;
  margin-bottom: 16px;
}

.hint {
  color: #666;
  font-size: 14px;
  margin-bottom: 16px;
}

.input-group {
  display: flex;
  gap: 8px;
  margin-bottom: 16px;
}

.input {
  flex: 1;
  padding: 8px 12px;
  border: 1px solid #ddd;
  border-radius: 4px;
  font-size: 14px;
}

.btn-add {
  padding: 8px 16px;
  background: #1989fa;
  color: #fff;
  border: none;
  border-radius: 4px;
  font-size: 14px;
}

.options-list {
  margin-bottom: 16px;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 12px;
  border-bottom: 1px solid #eee;
}

.option-item text {
  margin-left: 8px;
  flex: 1;
}

.delete-btn {
  color: #999;
  padding: 4px 8px;
}

.btn-primary {
  width: 100%;
  padding: 12px;
  background: #1989fa;
  color: #fff;
  border: none;
  border-radius: 8px;
  font-size: 16px;
  margin-top: 16px;
}

.btn-primary[disabled] {
  background: #ccc;
}

.score-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 0;
  border-bottom: 1px solid #eee;
}

.option-name {
  font-weight: bold;
}

.rate-group {
  display: flex;
  gap: 4px;
}

.rate-star {
  font-size: 20px;
  color: #ccc;
}

.rate-star.active {
  color: #fdbd2d;
}

.radio-group {
  display: flex;
  gap: 16px;
}

.radio-label {
  display: flex;
  align-items: center;
  gap: 4px;
}

.result-item {
  padding: 16px;
  margin: 8px 0;
  background: #f9f9f9;
  border-radius: 8px;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.result-name {
  font-weight: bold;
  font-size: 16px;
}

.result-tag {
  padding: 4px 8px;
  border-radius: 4px;
  font-size: 12px;
  background: #eee;
  color: #666;
}

.result-tag.winner {
  background: #1989fa;
  color: #fff;
}

.result-detail {
  color: #666;
  font-size: 14px;
}

.result-detail text {
  display: block;
  margin: 4px 0;
}

.total-score {
  font-weight: bold;
  color: #1989fa;
}

.summary {
  margin-top: 16px;
  padding: 16px;
  background: #f0f7ff;
  border-radius: 8px;
}

.summary-title {
  font-weight: bold;
  margin-bottom: 8px;
}